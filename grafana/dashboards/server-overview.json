        "justifyMode": "auto"
      },
      "targets": [ { "expr": "100 * (1 - (node_memory_MemAvailable_bytes{job=\"node_exporter\"} / node_memory_MemTotal_bytes{job=\"node_exporter\"}))", "refId": "A", "legendFormat": "Memory Used %" } ],
