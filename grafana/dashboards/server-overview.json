      "targets": [
        { "expr": "node_memory_MemTotal_bytes{job=\"node_exporter\"} - node_memory_MemAvailable_bytes{job=\"node_exporter\"}", "refId": "A", "legendFormat": "Used" },
        { "expr": "node_memory_MemAvailable_bytes{job=\"node_exporter\"}", "refId": "B", "legendFormat": "Free" }
