# ============================================================================
# Common Configuration
# ============================================================================
NODE_NAME=gpu-node-01

# ============================================================================
# Central Server Configuration (for docker-compose.central.yml)
# ============================================================================
# IP/hostname accessible from edge nodes for Prometheus scraping
CENTRAL_HOST=10.0.0.10

# Central service ports (host:container)
PROMETHEUS_PORT=9090
LOKI_PORT=3100
GRAFANA_PORT=3000

# Grafana admin credentials
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=changeMe123!

# ============================================================================
# Edge Node Configuration (for docker-compose.edge.yml)
# ============================================================================
# URL for Promtail to push logs to central Loki
# Must be accessible from edge nodes
LOKI_URL=http://10.0.0.10:3100/loki/api/v1/push

# Exporter ports (defaults: 9100, 9290, 9835)
NODE_EXPORTER_PORT=9100
IPMI_EXPORTER_PORT=9290
NVIDIA_GPU_EXPORTER_PORT=9835
